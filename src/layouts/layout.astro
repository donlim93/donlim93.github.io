---
import "../styles/global.css";
import "@fortawesome/fontawesome-free/css/all.min.css";
import Sidebar from "../components/Sidebar.astro";
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Font Awesome icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Custom cursor -->
    <!-- <div class="custom-cursor"></div> -->
    <!-- Site navigation -->
    <nav id="site-nav" style="visbility=hidden;">
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/papers">Papers</a></li>
        <li><a href="/coursework">Coursework</a></li>
        <li><a href="/certifications">Certifications</a></li>
        <li><a href="/worksamples">Work Samples</a></li>
        <li><a href="/tableau">Tableau Public</a></li>
      </ul>
      <!-- Mobile menu and theme toggles -->
      <div class="nav-controls">
        <button class="nav-toggle" aria-label="Menu">&#9776;</button>
        <button class="theme-toggle" aria-label="Toggle theme">
          <i class="fas fa-sun"></i>
        </button>
      </div>
      <!-- Overflow menu for collapsed items -->
      <ul class="nav-overflow hidden"></ul>
    </nav>

    <!-- Main content area -->
    <main>
      <Sidebar />
      <slot />
    </main>

    <!-- Site footer -->
    <footer>
      <a href="https://www.linkedin.com/in/lim-don/" target="_blank"
        ><i class="fab fa-linkedin"></i> LinkedIn</a
      >
      <a href="http://github.com/donlim93" target="_blank"
        ><i class="fab fa-github"></i> GitHub</a
      >
      <p>&copy; 2026 Don Lim</p>
    </footer>

    <!-- Custom cursor script -->
    <!--
